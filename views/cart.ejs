<h2>Корзина</h2>
<% if (items.length) { %>
    <% items.forEach((item, idx) => { %>
        <div style="display:flex; justify-content:space-between; margin:0.5rem 0;">
            <span><%= item.title %> — <%= item.price %> ₽</span>
            <a href="/cart/remove/<%= idx %>" class="btn secondary">Удалить</a>
        </div>
    <% }); %>
    <h3>Итого: <%= total %> ₽</h3>
    <form action="/checkout" method="POST"><button class="btn">Оформить заказ</button></form>
<% } else { %>
    <p>Корзина пуста</p>
<% } %>