<h2>Регистрация</h2>
<form method="POST">
    <div class="form-group"><label>Логин</label><input type="text" name="username" class="form-control" required></div>
    <div class="form-group"><label>Email</label><input type="email" name="email" class="form-control" required></div>
    <div class="form-group"><label>Пароль</label><input type="password" name="password" class="form-control" required></div>
    <button type="submit" class="btn">Зарегистрироваться</button>
</form>