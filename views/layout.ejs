<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Мир Книжек</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { background:#feffff; font-family: system-ui; color:#2c2b28; }
        .container { max-width:1400px; margin:0 auto; padding:0 20px; }
        header { background:#ffffffdd; backdrop-filter:blur(10px); border-bottom:1px solid #e2d4c0; padding:1rem 0; display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:1rem; margin-bottom:2rem; }
        header h1 a { text-decoration:none; background:linear-gradient(150deg,#000,#880d1e); -webkit-background-clip:text; background-clip:text; color:transparent; }
        nav { display:flex; gap:1rem; flex-wrap:wrap; }
        nav a { text-decoration:none; color:#4a3b2f; }
        .btn { background:#e9e0d3; border:none; border-radius:40px; padding:0.5rem 1rem; text-decoration:none; color:#4a3b2f; display:inline-block; margin:0.2rem 0; cursor:pointer; }
        .btn.secondary { background:#fff; border:1px solid #b0a088; }
        .books { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:1.5rem; margin-top:1rem; }
        .book { background:#f6f4f0; border-radius:14px; padding:1rem; text-align:center; }
        .img { background:#e9e0d3; aspect-ratio:3/4; display:flex; align-items:center; justify-content:center; font-size:2rem; border-radius:12px; margin-bottom:0.5rem; }
        .price { font-weight:bold; color:#b1622c; margin:0.5rem 0; }
        footer { background:#e7dbcd; text-align:center; padding:1rem; margin-top:3rem; }
        .search { display:flex; gap:0.5rem; }
        .search input { padding:0.5rem; border-radius:50px; border:1px solid #dfd2c0; width:250px; }
        .alert { padding:0.75rem; margin-bottom:1rem; border-left:4px solid #8b735b; background:#fffef7; border-radius:8px; }
        .form-group { margin-bottom:1rem; }
        .form-control { width:100%; padding:0.5rem; border:1px solid #ddd; border-radius:8px; }
        @media (max-width:768px) { header { flex-direction:column; } .search input { width:100%; } }
    </style>
</head>
<body>
<div class="container">
    <header>
        <h1><a href="/">📚 МИР КНИЖЕК</a></h1>
        <form action="/" method="GET" class="search">
            <input type="text" name="search" placeholder="Поиск" value="<%= locals.search || '' %>">
            <button type="submit">Найти</button>
        </form>
        <nav>
            <a href="/cart">🛒 Корзина (<%= cartCount %>)</a>
            <% if (user) { %>
                <a href="/my-reservations">📌 Мои брони</a>
                <% if (user.is_admin) { %><a href="/admin">⚙️ Админка</a><% } %>
                <a href="/profile">👤 <%= user.username %></a>
                <a href="/logout">Выход</a>
            <% } else { %>
                <a href="/login">Вход</a>
                <a href="/register">Регистрация</a>
            <% } %>
        </nav>
    </header>
    <% if (flash && flash.length) { flash.forEach(function(msg){ %>
        <div class="alert"><%= msg %></div>
    <% }); } %>
    <main><%- body %></main>
    <footer>© 2026 Книжный магазин</footer>
</div>
</body>
</html>